{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Remote Attach",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "${config:pi_hostname}",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "${config:pi_root_folder}"
        }
      ],
      "preLaunchTask": "Debug",
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}